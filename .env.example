# ── Application ────────────────────────────────────────────────
APP_NAME="Multi-Agent Task Manager"
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────
# SQLite file path. On Render, use /var/data/tasks.db with a disk mount.
DATABASE_URL=sqlite:///./tasks.db

# ── Telegram ───────────────────────────────────────────────────
# Get a token from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here
# Optional: restrict the bot to one chat id (leave empty to allow all)
TELEGRAM_ALLOWED_CHAT_ID=

# ── Gemini ─────────────────────────────────────────────────────
# Get an API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── Reminders ──────────────────────────────────────────────────
# 24h clock, server-local time
DAILY_REMINDER_HOUR=8
DAILY_REMINDER_MINUTE=30
TIMEZONE=Asia/Kolkata
